{
  "name": "@fleettools/opencode-plugin",
  "version": "0.7.0",
  "description": "FleetTools OpenCode Plugin - AI Agent Coordination System",
  "type": "module",
  "main": "./dist/minimal.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --external zod && bun build src/minimal.ts --outdir dist --target bun",
    "dev": "bun build src/index.ts --outdir dist --target bun --watch",
    "clean": "rm -rf dist",
    "test": "bun test-contract.ts && bun test-exists.ts && bun test-smoke.ts --cwd test",
    "package": "npm run build && npm publish"
  },
  "keywords": [
    "fleettools",
    "opencode",
    "ai",
    "agents",
    "coordination",
    "cli"
  ],
  "author": "FleetTools",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "1.1.47",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v1truv1us/fleettools.git",
    "directory": "plugins/opencode"
  }
}
